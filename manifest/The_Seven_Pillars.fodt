     <text:p text:style-name="P41"><text:bookmark text:name="user-content-fn-3 Copy 1"/>Recent shadow-banning and self-censorship reports. <text:a xlink:type="simple" xlink:href="#user-content-fnref-3" text:style-name="Internet_20_link" text:visited-style-name="Visited_20_Internet_20_Link">↩</text:a> <text:a xlink:type="simple" xlink:href="#user-content-fnref-3-2" text:style-name="Internet_20_link" text:visited-style-name="Visited_20_Internet_20_Link">↩</text:a><text:a xlink:type="simple" xlink:href="#user-content-fnref-3-2" text:style-name="Internet_20_link" text:visited-style-name="Visited_20_Internet_20_Link"><text:span text:style-name="T5">2</text:span></text:a></text:p>
